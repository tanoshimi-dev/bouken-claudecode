# =============================================================================
# Production Environment Variables
# Copy to .env.prod and fill in actual values
# =============================================================================

# PostgreSQL container
POSTGRES_USER=learn_ai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=learn_ai

# Database (use "postgres" hostname — the Docker service name)
DATABASE_URL="postgresql://learn_ai:CHANGE_ME_STRONG_PASSWORD@postgres:5432/learn_ai"

# JWT (generate with: openssl rand -base64 48)
JWT_SECRET="CHANGE_ME_at_least_32_characters_long"
JWT_REFRESH_SECRET="CHANGE_ME_at_least_32_characters_long"

# OAuth - Google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://backend.ai.bouken.app/api/auth/google/callback"

# OAuth - GitHub
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GITHUB_REDIRECT_URI="https://backend.ai.bouken.app/api/auth/github/callback"

# OAuth - Microsoft
MICROSOFT_TENANT="common"
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_REDIRECT_URI="https://backend.ai.bouken.app/api/auth/microsoft/callback"

# OAuth - Apple
APPLE_CLIENT_ID=""
APPLE_TEAM_ID=""
APPLE_KEY_ID=""
APPLE_PRIVATE_KEY=""
APPLE_REDIRECT_URI="https://backend.ai.bouken.app/api/auth/apple/callback"

# OAuth - LINE
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""
LINE_REDIRECT_URI="https://backend.ai.bouken.app/api/auth/line/callback"

# App URLs
APP_URL="https://ai.bouken.app"
API_URL="https://backend.ai.bouken.app"

# Web build arg (baked into client JS at build time)
NEXT_PUBLIC_API_URL="https://backend.ai.bouken.app"

# Cookie (parent domain for cross-subdomain sharing)
COOKIE_DOMAIN=".ai.bouken.app"

# Mobile deep-link scheme
MOBILE_SCHEME="learnclaudecode"
