{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=true prisma generate",
    "db:seed": "tsx --env-file=.env ../../scripts/seed-content.ts",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "6.19.2",
    "arctic": "^3.5.0",
    "hono": "^4.7.0",
    "jose": "^6.0.0",
    "zod": "^3.24.0",
    "@learn-claude-code/shared-types": "workspace:*",
    "@learn-claude-code/zod-schemas": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22",
    "prisma": "6.19.2",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
